<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShopRetail">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ShopRetail">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.inventory.InventoryActivity"
            android:label="Inventory"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.ShopRetail" />
        <activity
            android:name=".ui.inventory.AddProductActivity"
            android:label="Add Product"
            android:parentActivityName=".ui.inventory.InventoryActivity"
            android:theme="@style/Theme.ShopRetail" />
        <activity
            android:name=".ui.sales.LogSaleActivity"
            android:label="Log Sale"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.ShopRetail" />
        <activity
            android:name=".ui.sales.DashboardActivity"
            android:label="Dashboard"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.ShopRetail" />
        <activity
            android:name=".ui.analytics.AutomationDashboardActivity"
            android:label="Automation"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.ShopRetail" />
    </application>

</manifest>